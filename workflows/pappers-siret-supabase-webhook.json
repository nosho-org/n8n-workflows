      ],
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst siege = d.siege || {};\n\nreturn [{\n  json: {\n    name: d.denomination || d.nom_entreprise || '',\n    siret: siege.siret || '',\n    billing_name: d.denomination || d.nom_entreprise || '',\n    billing_address: siege.adresse_ligne_1 || siege.adresse || '',\n    billing_zipcode: siege.code_postal || '',\n    billing_city: siege.ville || '',\n    updated_at: new Date().toISOString()\n  }\n}];"
      }
    },
