    {
      "id": "5b0c3a4d-6e7f-8a9b-0c1d-2e3f4a5b6c7d",
      "name": "Format Résultats",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        -240
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst results = (data.resultats || []).slice(0, 10);\n\nconst formatted = results.map((r, i) => {\n  const siege = r.siege || {};\n  const addr = [siege.adresse_ligne_1, siege.code_postal, siege.ville]\n    .filter(Boolean).join(', ');\n  return {\n    index: i + 1,\n    siret: siege.siret || '',\n    siren: r.siren || '',\n    name: r.denomination || r.nom_entreprise || '',\n    address: addr,\n    legal_form: r.forme_juridique || ''\n  };\n});\n\nconst list = formatted.length > 0\n  ? formatted.map(r =>\n      `${r.index}. ${r.name}\\n   SIRET: ${r.siret}\\n   ${r.address}\\n   ${r.legal_form}`\n    ).join('\\n\\n')\n  : 'Aucune entreprise trouvée.';\n\nreturn [{\n  json: {\n    total: data.total || 0,\n    results: formatted,\n    message: formatted.length > 0\n      ? `${formatted.length} résultat(s) trouvé(s) :\\n\\n${list}\\n\\nEnvoyez { \"siret\": \"XXXXXXXXXXXXXX\" } pour confirmer.`\n      : list\n  }\n}];"
      }
    },
    {
      "id": "6c1d4b5e-7f8a-9b0c-1d2e-3f4a5b6c7d8e",
      "name": "Répondre Recherche",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
